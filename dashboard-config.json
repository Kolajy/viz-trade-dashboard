  },
  "fedHealthDashboard": {
    "dataUrl": "./data.json",
    "source": "Federal Reserve Board",
    "assetsConfig": {
      "treasuries": { "key": "fedHealth.treasuryHoldings", "label": "U.S. Treasuries", "color": "var(--color-up)" },
      "mbs": { "key": "fedHealth.mbsHoldings", "label": "Mortgage-Backed Securities", "color": "#8c52ff" },
