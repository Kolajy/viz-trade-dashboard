      { "key": "3Y", "label": "3-Year" },
      { "key": "5Y", "label": "5-Year" },
      { "key": "7Y", "label": "7-Year" },
      { "key": "10Y", "label": "10-Year" },
      { "key": "20Y", "label": "20-Year" },
      { "key": "30Y", "label": "30-Year" }
